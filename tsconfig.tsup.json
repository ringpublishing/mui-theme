{
    "extends": "@ringieraxelspringer/tsconfig",
    "compilerOptions": {
        "jsx": "react",
        "lib": [
            "dom",
            "esnext"
        ],
        "skipLibCheck": true,
        "noEmit": false,
        "rootDir": "src",
        "outDir": "dist",
        "declaration": true,
        "declarationMap": false,
        "emitDeclarationOnly": true
    },
    "include": [
        "src/**/*"
    ]
}
